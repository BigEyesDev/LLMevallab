```gitignore
# Environment
.env
venv/
__pycache__/
*.pyc

# Data (too large for git)
data/raw/
data/processed/

# Outputs
outputs/results/

# Personal learning logs (local only — not for public repo)
docs/learning/

# Personal planning / specs / article drafts (local only)
files/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS
.DS_Store
```